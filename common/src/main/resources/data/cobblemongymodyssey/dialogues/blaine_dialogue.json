{
  "initializationAction": "(q.npc.is_in_battle_with(q.player) || !q.npc.is_doing_activity('minecraft:idle', 'cobblemon:battling')) ? q.dialogue.close()",
  "speakers": {
    "npc": {
      "name": {
        "type": "expression",
        "expression": "q.npc.name"
      },
      "face": "q.npc.face(false);"
    },
    "player": {
      "face": "q.player.face();",
      "name": {
        "type": "expression",
        "expression": "q.player.username"
      }
    }
  },
  "pages": [
    {
      "id": "npc-chat",
      "speaker": "npc",
      "lines": [
        "My Fire Pokémon will reduce you to ashes! I never lose!",
        "The Volcano Badge is mine — prove me wrong if you can!"
      ],
      "input": {
        "type": "option",
        "vertical": false,
        "options": [
          {
            "text": "Battle!",
            "value": "battle",
            "action": [
              "q.dialogue.close();",
              "q.npc.start_battle(q.player);"
            ],
            "isSelectable": "c.npc.can_battle;"
          },
          {
            "text": "Not yet",
            "value": "cancel",
            "action": [
              "q.dialogue.close()"
            ]
          }
        ]
      }
    }
  ]
}
